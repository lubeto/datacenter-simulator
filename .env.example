# =============================================================================
# DC Monitoring Simulator — Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# NUNCA comitas .env a git — ya está en .gitignore
# =============================================================================

# ── Seguridad ──────────────────────────────────────────────────────────────
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTE_SECRETO_EN_PRODUCCION_minimo32chars!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Servidor ───────────────────────────────────────────────────────────────
HOST_PORT=8000
DEBUG=false
ENVIRONMENT=production

# ── Base de datos ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/simulator.db

# ── Instructor / Admin por defecto ─────────────────────────────────────────
ADMIN_EMAIL=instructor@datacenter.edu
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Instructor Principal

# ── Simulación ─────────────────────────────────────────────────────────────
NUM_NODES=12
METRICS_INTERVAL_SECONDS=2
AUTO_ATTACK_ENABLED=true
AUTO_ATTACK_MIN_INTERVAL_MIN=5
AUTO_ATTACK_MAX_INTERVAL_MIN=20

# ── CORS — orígenes permitidos separados por coma ──────────────────────────
# En Render.com pon la URL de tu servicio: https://mi-simulador.onrender.com
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
